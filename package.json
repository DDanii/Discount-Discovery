{
  "name": "discount-discovery",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "dev-delete-db": "rm -f prisma/dev.db && nuxt dev",
    "start": "nuxt start",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "zhelp": "ts-to-zod --help",
    "gen-zod": "ts-to-zod utils/types/shopConfig.ts utils/validators/shopConfigSchema.ts",
    "gen-schema": "ts-json-schema-generator --path 'utils/types/shopConfig.ts' --type 'ShopConfig' > shopConfigSchema.json",
    "gen-prisma": "prisma generate",
    "gen": "npm run gen-zod && npm run gen-schema && npm run gen-prisma",
    "migrate-create": "prisma migrate dev",
    "migrate-prisma": "prisma migrate deploy",
    "docker": "docker compose -f dev.yml build && docker compose -f dev.yml up",
    "couch": "docker compose -f couchdb.yml up"
  },
  "dependencies": {
    "@nuxt/eslint": "^1.13.0",
    "@prisma/adapter-better-sqlite3": "^7.3.0",
    "@prisma/client": "^7.3.0",
    "@types/pouchdb": "^6.4.2",
    "@types/pouchdb-upsert": "^2.2.9",
    "@vite-pwa/nuxt": "^1.1.1",
    "cron": "^4.4.0",
    "eslint": "^9.39.2",
    "fs": "^0.0.1-security",
    "node-html-parser": "^7.0.2",
    "nuxt": "^4.3.0",
    "nuxt-toast": "^1.4.0",
    "pouchdb": "^9.0.0",
    "pouchdb-authentication": "^1.1.3",
    "pouchdb-find": "^9.0.0",
    "pouchdb-upsert": "^2.2.0",
    "prisma": "^7.3.0",
    "vue": "^3.5.27",
    "vue-router": "^5.0.2",
    "yaml": "^2.8.2"
  },
  "devDependencies": {
    "@nuxtjs/tailwindcss": "^6.14.0",
    "@types/node": "^25.2.0",
    "@vite-pwa/assets-generator": "^1.0.2",
    "ts-json-schema-generator": "^2.5.0",
    "ts-to-zod": "^5.1.0",
    "tsx": "^4.21.0"
  }
}
